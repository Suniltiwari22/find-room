<% layout("/layouts/boilerplate")%>
<%=success%>
<body>
    <style>
#filters{
    display:flex;
    flex-wrap:wrap;
    justify-content:center;
    gap:1rem;
    margin-top:1rem;
}

.filter{
    text-align:center;
    opacity:0.7;
    min-width:70px;
}

.filter:hover{
    opacity:1;
    cursor:pointer;
}

.card-img-top{
    height:20rem;
    object-fit:cover;
}

.listing-link{
    text-decoration:none;
    color:inherit;
}

@media (max-width:768px){

    #filters{
        gap:0.7rem;
    }

    .filter{
        min-width:60px;
        font-size:0.85rem;
    }

    .card-img-top{
        height:15rem;
    }
}
</style>

     <div id="filters">
      <div class="filter">
       <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p> 
      </div>
      <div class="filter">
       <div><i class="fa-solid fa-restroom"></i></div>
      <p>Rooms</p> 
      </div>
      <div class="filter">
       <div><i class="fa-solid fa-monument"></i></div>
      <p>Iconoc city</p> 
      </div>
      <div class="filter">
       <div><i class="fa-solid fa-circle-notch"></i></div>
      <p>suffering</p> 
      </div>
      <div class="filter">
       <div><i class="fa-solid fa-location-arrow"></i></div>
      <p>Location</p> 
      </div>
      <div class="filter">
       <div><i class="fa-solid fa-house"></i></div>
      <p>House</p> 
      </div>
      <div class="filter">
       <div><i class="fa-solid fa-image"></i></div>
      <p>Image</p> 
      </div>
     </div>

<div class="row">
    <% for(let listing of allListings){ %>

        <div class="col-lg-4 col-md-6 col-sm-12 mb-4">
            <a href="/listings/<%= listing._id %>" class="listing-link">
                <div class="card h-100">
                    <img
                        src="<%= listing.image.url %>"
                        class="card-img-top"
                        alt="listing image"
                    >

                    <div class="card-body">
                        <h5><%= listing.title %></h5>
                        <p>₹ <%= listing.price.toLocaleString("en-IN") %> / night</p>
                    </div>
                </div>
            </a>
        </div>

    <% } %>
</div>


