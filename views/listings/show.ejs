<% layout("/layouts/boilerplate") %>

<div class="row">
  <div class="col-12 col-md-10 offset-md-1 col-lg-8 offset-lg-2">

    <h3 class="mb-3"><%= listing.title %></h3>

    <div class="card shadow-sm">
      <img class="show-img" src="<%= listing.image.url %>" alt="listing_image">

      <div class="card-body">
        <p class="card-text">
          <%= listing.description %><br>
          ₹<%= Number(listing.price).toLocaleString("en-IN") %><br>
          <%= listing.location %><br>
          <%= listing.country %>
        </p>

        <div class="mt-3 d-flex flex-column flex-sm-row gap-2">

          <a href="/listings/<%= listing._id %>/edit"
             class="btn btn-primary btn-sm">
            ✏️ Edit
          </a>

          <form method="POST"
                action="/listings/<%= listing._id %>?_method=DELETE"
                onsubmit="return confirm('Are you sure you want to delete this listing?');">

            <button class="btn btn-danger btn-sm">
              🗑 Delete
            </button>

          </form>

        </div>
      </div>
    </div>

  </div>

  <!-- Review Form -->
  <div class="col-12 col-md-10 offset-md-1 col-lg-8 offset-lg-2 mt-4">

    <h4 class="mb-3">Leave a Review</h4>

    <form
      action="/listings/<%= listing._id %>/reviews"
      method="POST"
      class="needs-validation"
      novalidate
    >

      <div class="mb-3">
        <label for="rating" class="form-label">Rating</label>

        <input
          type="range"
          class="form-range"
          min="1"
          max="5"
          value="3"
          id="rating"
          name="review[rating]"
          oninput="ratingValue.innerText = this.value"
        >

        <div class="text-muted">
          Selected Rating:
          <span id="ratingValue">3</span> ⭐
        </div>
      </div>

      <div class="mb-3">
        <label for="comments" class="form-label">Comments</label>

        <textarea
          class="form-control"
          name="review[comment]"
          id="comments"
          rows="5"
          required
        ></textarea>

        <div class="invalid-feedback">
          Please submit a comment.
        </div>
      </div>

      <button class="btn btn-dark">
        Submit Review
      </button>

    </form>

    <!-- Submit Section -->

<!-- What this place offers -->
<section class="amenities-section">
    <h2>What this place offers</h2>

    <div class="amenities-grid">
        <div class="amenity-item">
            <span class="icon">🍳</span>
            <span>Kitchen</span>
        </div>

        <div class="amenity-item">
            <span class="icon">📶</span>
            <span>Wi-Fi</span>
        </div>

        <div class="amenity-item">
            <span class="icon">🅿️</span>
            <span>Free on-street parking</span>
        </div>

        <div class="amenity-item">
            <span class="icon">📺</span>
            <span>TV</span>
        </div>

        <div class="amenity-item">
            <span class="icon">🛗</span>
            <span>Lift</span>
        </div>

        <div class="amenity-item">
            <span class="icon">❄️</span>
            <span>Air conditioning</span>
        </div>

        <div class="amenity-item">
            <span class="icon">🛁</span>
            <span>Bath</span>
        </div>

        <div class="amenity-item">
            <span class="icon">🌿</span>
            <span>Private patio or balcony</span>
        </div>

        <div class="amenity-item">
            <span class="icon">📹</span>
            <span>Exterior security cameras on property</span>
        </div>

        <div class="amenity-item unavailable">
            <span class="icon">🚫</span>
            <span>
                Carbon monoxide alarm
                <small>Unavailable</small>
            </span>
        </div>
    </div>

    <button class="show-more-btn">
        Show all 35 amenities →
    </button>
</section>

<!-- Location Section -->
<section class="location-section">
    <h2>Location</h2>
    <!-- Your location content -->
</section>

</div>

    <!-- Reviews List -->
    <div class="mt-4">

      <% for(let review of listing.reviews){ %>

        <div class="card mb-2">
          <div class="card-body">
            <h6><%= review.rating %> ⭐</h6>
            <p class="mb-0"><%= review.comment %></p>
          </div>
        </div>

      <% } %>

    </div>

  </div>

  <!-- Map Section -->
  <div class="row">
    <div class="col-12 col-md-10 offset-md-1 col-lg-8 offset-lg-2">

        <h3 class="mt-5">Where you'll be</h3>

        <div id="map"></div>

    </div>
</div>


<script>
const map = L.map('map').setView([26.8467, 80.9462], 10);

L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
}).addTo(map);

L.marker([26.8467, 80.9462]).addTo(map);

setTimeout(() => {
    map.invalidateSize();
}, 100);
</script>

<!-- Booking Section -->
<section class="booking-section">
    <h2>Reserve Your Stay</h2>

    <form class="booking-form">

        <div class="booking-group">
            <label for="checkin">Check-in</label>
            <input type="date" id="checkin" required>
        </div>

        <div class="booking-group">
            <label for="checkout">Check-out</label>
            <input type="date" id="checkout" required>
        </div>

        <div class="booking-group">
            <label for="guests">Guests</label>
            <select id="guests" required>
                <option value="">Select guests</option>
                <option>1 Guest</option>
                <option>2 Guests</option>
                <option>3 Guests</option>
                <option>4 Guests</option>
                <option>5+ Guests</option>
            </select>
        </div>

        <button type="submit" class="book-btn">
            Book Now
        </button>

    </form>

    <p class="booking-note">
        You won't be charged yet. Your reservation request will be reviewed by the host.
    </p>
</section>
