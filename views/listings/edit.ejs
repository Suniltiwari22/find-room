<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Listing</title>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f4f6f9;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .container {
            background: #fff;
            padding: 30px 40px;
            border-radius: 10px;
            width: 420px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        }

        h2 {
            text-align: center;
            margin-bottom: 20px;
            font-weight: 500;
        }

        .form-group {
            margin-bottom: 15px;
        }

        label {
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 5px;
            display: block;
        }

        input, textarea {
            width: 100%;
            padding: 10px;
            border-radius: 6px;
            border: 1px solid #ccc;
            font-size: 14px;
            outline: none;
        }

        input:focus, textarea:focus {
            border-color: #007BFF;
        }

        textarea {
            resize: none;
            height: 80px;
        }

        .btn {
            width: 100%;
            padding: 10px;
            background-color: #007BFF;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            cursor: pointer;
            margin-top: 10px;
        }

        .btn:hover {
            background-color: #0056b3;
        }

        .image-preview {
            width: 100%;
            height: 180px;
            object-fit: cover;
            border-radius: 8px;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>

<div class="container">
    <h2>Edit Listing</h2>

    <form action="/listings/<%= listing._id %>?_method=PUT" method="POST" novalidate
        class="needs-validation">

        <!-- Image Preview -->
        <img src="<%= listing.image %>" alt="Listing Image" class="image-preview">

        <div class="form-group">
            <label>Title</label>
            <input type="text" name="title" value="<%= listing.title %>" required>
        </div>

        <div class="form-group">
            <label>Description</label>
            <textarea name="description" required><%= listing.description %></textarea>
        </div>

        <div class="form-group">
            <label>Image URL</label>
            <input type="text" name="image" value="<%= listing.image %> required">
        </div>

        <div class="form-group">
            <label>Price</label>
            <input type="number" name="price" value="<%= listing.price %>" required>
        </div>

        <div class="form-group">
            <label>Country</label>
            <input type="text" name="country" value="<%= listing.country %> required">
        </div>

        <div class="form-group">
            <label>Location</label>
            <input type="text" name="location" value="<%= listing.location %> required">
        </div>

        <button type="submit" class="btn">Update Listing</button>

    </form>
</div>
</body>
</html>
